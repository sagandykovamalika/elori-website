{
  "$schema": "https://lingo.dev/schema/i18n.json",
  "version": "1.15",
  "locale": {
    "source": "en",
    "targets": ["es", "fr", "de", "ru"]
  },
  "buckets": {
    "html": {
      "include": [
        "[locale]/index.html",
        "[locale]/faq/index.html",
        "[locale]/privacy-policy/index.html",
        "[locale]/terms-of-use/index.html"
      ]
    }
  }
}
